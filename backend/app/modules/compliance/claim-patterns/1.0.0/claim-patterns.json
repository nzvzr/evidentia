  "patterns": [
    {
      "id": "compliance.administrative-access-mfa",
      "version": "1.0.0",
      "title": "Administrative access requires multi-factor authentication",
      "family": "assertion",
      "claimType": "control_requirement",
      "priorityHint": "High",
      "enabled": true,
      "matcher": {"primitive": "all_of", "children": [
        {"primitive": "token_any", "terms": ["administrative", "administrator", "privileged"]},
        {"primitive": "token_any", "terms": ["mfa", "multi-factor authentication", "multifactor authentication"]}
      ]},
      "evidenceNeeds": [
        {"id": "access-scope", "required": true, "weight": 1.0, "purpose": "support", "matcher": {"primitive": "token_any", "terms": ["administrative", "administrator", "privileged"]}},
        {"id": "mfa-control", "required": true, "weight": 1.5, "purpose": "support", "matcher": {"primitive": "token_any", "terms": ["mfa", "multi-factor authentication", "multifactor authentication"]}},
        {"id": "mandatory-language", "required": true, "weight": 1.0, "purpose": "support", "matcher": {"primitive": "obligation_term", "terms": ["must", "shall", "required", "requires"]}},
        {"id": "conflict-negation", "required": false, "weight": 1.0, "purpose": "conflict", "matcher": {"primitive": "proximity", "left": ["not", "without", "optional", "exempt"], "right": ["mfa", "authentication"], "maxTokens": 6}}
      ],
      "gatePolicy": {"id": "deterministic-support-standard", "version": "1.0.0"},
      "output": {"kind": "risk", "statement": "Administrative access requires multi-factor authentication.", "severity": "High", "title": "Administrative MFA requirement requires implementation assurance", "description": "The policy requires MFA for administrative or privileged access; implementation evidence should be verified.", "businessImpact": "A documented control without implementation assurance can leave privileged access exposed.", "recommendedFix": "Verify enforcement and retain current MFA configuration evidence.", "owner": "Security"},
      "provenance": {"changelog": "Initial M5a control pattern.", "fixtures": ["administrative-access-mfa"]}
    },
    {
