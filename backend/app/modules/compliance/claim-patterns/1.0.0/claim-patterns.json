        {"id": "mandatory-language", "required": true, "weight": 0.5, "purpose": "support", "matcher": {"primitive": "obligation_term", "terms": ["must", "shall", "required", "requires"]}},
        {"id": "conflict-negation", "required": false, "weight": 1.0, "purpose": "conflict", "matcher": {"primitive": "proximity", "left": ["not", "never", "optional"], "right": ["review", "reviewed"], "maxTokens": 5}}
      ],
      "gatePolicy": {"id": "deterministic-support-standard", "version": "1.0.0"},
      "output": {"kind": "risk", "statement": "Privileged access is periodically reviewed.", "severity": "Medium", "title": "Privileged-access review cadence requires evidence", "description": "The policy mandates periodic review of privileged access; completed review evidence should be retained.", "businessImpact": "Unverified access recertification can leave obsolete privileged access active.", "recommendedFix": "Retain the latest review record and assigned remediation owners.", "owner": "Security"},
      "provenance": {"changelog": "Initial M5a control pattern.", "fixtures": ["privileged-access-periodic-review"]}
