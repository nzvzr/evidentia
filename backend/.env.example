# Evidentia Python backend configuration
#
# The backend works fully offline with deterministic agents and NO keys.
# To enable LLM-assisted refinement, set EVIDENTIA_USE_LLM=true and add a key.
# Copy this file to .env (never commit real keys).

# --- LLM provider keys (owned by the backend; never sent to the frontend) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline configuration ---
EVIDENTIA_USE_LLM=false
EVIDENTIA_LLM_PROVIDER=openai
EVIDENTIA_LLM_MODEL=gpt-4o-mini
