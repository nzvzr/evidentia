# Evidentia Python backend configuration
#
# This backend owns AUTHENTICATION, TENANCY and PERSISTENCE. It is required — the
# frontend cannot authenticate anyone without it, and there is no degraded mode.
#
# The generation pipeline still runs with no LLM key (deterministic mode).
# Copy this file to .env (never commit real secrets).

# ==========================================================================
# PRODUCTION (EVIDENTIA_ENV=production): startup FAILS if any of these is unsafe
# ==========================================================================

# "development" or "production". Production enables fail-fast config validation.
EVIDENTIA_ENV=development

# Signing key for JWT access tokens. REQUIRED in production. Anyone who recovers
# this key can mint a token for any user in any tenant, so a weak value forfeits
# every other control in the system.
#
# Same gate as EVIDENTIA_BFF_SECRET below: this must be a CRYPTOGRAPHICALLY
# GENERATED secret — the base64url or hex encoding of at least 32 random bytes.
# Generate it with EXACTLY this command and paste the output:
#
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# (token_urlsafe(32) and token_hex(32) are also accepted.) Startup REFUSES the
# dev default, known-weak values, repeated blocks, sequential runs,
# dictionary-like strings, narrow alphabets, low estimated entropy, highly
# compressible values, and anything that is not a valid ≥32-byte encoding.
# "32 characters long" is NOT sufficient.
JWT_SECRET=

# Shared secret proving a request arrived via the Next.js BFF. REQUIRED in
# production whenever EVIDENTIA_TRUSTED_PROXY_COUNT > 0 — otherwise a directly
# reachable backend would believe any client-supplied X-Forwarded-For and every
# per-IP rate limit would silently stop working.
#
# In production this must be a CRYPTOGRAPHICALLY GENERATED secret, not merely a
# long one. Generate it with EXACTLY this command and paste the output:
#
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# (hex is also accepted: python -c "import secrets; print(secrets.token_hex(32))")
#
# Startup REFUSES anything that is not the base64url or hex encoding of at least
# 32 random bytes, and additionally refuses known-weak values, repeated blocks,
# sequential runs, dictionary-like strings, low estimated entropy, and highly
# compressible values. "32 characters long" is NOT sufficient: a value such as
# abcd1234abcd1234abcd1234abcd1234 passes a length check and is guessed in seconds,
# and a guessable BFF secret is worth exactly as much as no BFF secret.
#
# Set the SAME value in the frontend environment.
EVIDENTIA_BFF_SECRET=

# Reverse-proxy hops in front of this backend whose X-Forwarded-For can be trusted.
#   0 = ignore XFF entirely, use the TCP peer (safe, but behind the BFF every user
#       shares ONE IP budget — a self-inflicted denial of service)
#   1 = the normal topology (backend behind the Next.js BFF)
# Only the Nth-from-the-right XFF entry is believed. X-Real-IP is NEVER trusted.
EVIDENTIA_TRUSTED_PROXY_COUNT=0

# Allowed CORS origins. "*" is REFUSED in production; list explicit origins:
#   EVIDENTIA_CORS_ORIGINS=https://evidentia.example.com
EVIDENTIA_CORS_ORIGINS=*

# --- Email (password reset + email verification) ---------------------------
# Production requires a REAL sender: EVIDENTIA_EMAIL_BACKEND=smtp with a host.
#   smtp    → real delivery (the only backend production accepts)
#   console → logs the link. DEVELOPMENT ONLY: that link is a single-use
#             account-takeover credential and must never reach a production log.
#   noop    → discards the message, so reset/verification only LOOK like they work.
#
# NOT YET VERIFIED AGAINST A REAL PROVIDER. The SMTP sender is stdlib smtplib with
# STARTTLS and is covered only by config/startup tests — no live delivery test has
# been run. Send yourself a real password-reset email through YOUR provider before
# relying on it: if delivery silently fails, password reset is unavailable and users
# are locked out.
EVIDENTIA_EMAIL_BACKEND=console
EVIDENTIA_SMTP_HOST=
EVIDENTIA_SMTP_PORT=587
EVIDENTIA_SMTP_USER=
EVIDENTIA_SMTP_PASSWORD=
EVIDENTIA_SMTP_STARTTLS=true
EVIDENTIA_SMTP_FROM=no-reply@evidentia.app

# Base URL used to build verification/reset links (the frontend origin).
EVIDENTIA_PUBLIC_APP_URL=http://localhost:3000

# Require a confirmed email address before tenant-scoped routes. Recommended: true.
EVIDENTIA_REQUIRE_EMAIL_VERIFICATION=false

# --- Database ---------------------------------------------------------------
# Authentication, tenancy and report persistence ALL require the database, so
# EVIDENTIA_DB_ENABLED=false is REFUSED in production.
#
# SQLite (empty DATABASE_URL) is for local development ONLY. Do not use it for a
# public beta: on most container hosts the filesystem is EPHEMERAL, so every
# redeploy silently destroys all users and reports. Use managed PostgreSQL:
#   DATABASE_URL=postgresql://user:password@db-host:5432/evidentia
DATABASE_URL=
EVIDENTIA_DB_ENABLED=true

# --- Tenant document corpus (ingestion, M1+) --------------------------------
# Master switch for customer-document ingestion. OFF (default) means the
# ingestion schema/seams are inert and upload endpoints return an explicit 403
# (tenant_corpus_disabled) and the ingestion worker is never started. Turning
# it off does not authorize authenticated generation to use sample evidence.
EVIDENTIA_TENANT_CORPUS_ENABLED=false

# Independent M4 rollout gate for authenticated tenant-grounded reports. OFF
# returns tenant_generation_disabled; it never falls back to the demo corpus.
EVIDENTIA_TENANT_GENERATION_ENABLED=false
# tenant-lexical-v1 deterministic retrieval bounds.
EVIDENTIA_TENANT_RETRIEVAL_MAX_DOCUMENTS=50
EVIDENTIA_TENANT_RETRIEVAL_MAX_CANDIDATE_SECTIONS=500
EVIDENTIA_TENANT_RETRIEVAL_MAX_SELECTED_SECTIONS=40
EVIDENTIA_TENANT_RETRIEVAL_MAX_TOTAL_CHARS=60000
EVIDENTIA_TENANT_RETRIEVAL_PER_DOCUMENT_CAP=10
EVIDENTIA_TENANT_EVIDENCE_EXCERPT_CHARS=1200
EVIDENTIA_REPORT_CACHE_MAX_ENTRIES=128

# --- Document ingestion (M2: MD/TXT upload + in-process worker) --------------
# Per-file upload cap in bytes (enforced while streaming; Content-Length is
# never trusted alone). The request-body cap is raised only for the multipart
# upload routes, to this value plus framing overhead.
EVIDENTIA_UPLOAD_MAX_FILE_BYTES=2097152
# Extracted-character cap: larger text fails typed (extraction_too_large),
# never silently truncated.
EVIDENTIA_MAX_EXTRACTED_CHARS=1000000
# Files per upload request (M2 accepts exactly one).
EVIDENTIA_UPLOAD_MAX_FILES=1
# Tenant quota foundations (abuse bounds; commercial plans are out of scope).
EVIDENTIA_TENANT_MAX_DOCUMENTS=500
EVIDENTIA_TENANT_MAX_TOTAL_BYTES=104857600
# In-process worker (single-instance posture): bounded thread count, poll
# interval, stale-heartbeat threshold, and the attempts cap per job.
EVIDENTIA_INGESTION_WORKER_COUNT=1
EVIDENTIA_INGESTION_POLL_SECONDS=2.0
EVIDENTIA_INGESTION_STALE_SECONDS=300
EVIDENTIA_INGESTION_MAX_ATTEMPTS=3
# Upload rate limits (per window seconds derive from the *_WINDOW settings).
RL_UPLOAD_IP_LIMIT=40
RL_UPLOAD_USER_LIMIT=20
RL_UPLOAD_TENANT_LIMIT=60

# --- Token lifetimes --------------------------------------------------------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60

# --- Rate limiting ----------------------------------------------------------
# A SINGLE BACKEND INSTANCE IS REQUIRED until a shared rate-limit store exists.
# Counters are PER-PROCESS and IN-MEMORY: N replicas multiply every limit by N, and
# a restart clears them. Do not scale this service horizontally — implement the
# RateLimitStore protocol against Redis, or enforce the limits at an API gateway,
# first. The store is bounded (LRU eviction) so a flood of unique emails/tokens
# cannot exhaust memory.
EVIDENTIA_RATE_LIMIT_ENABLED=true
EVIDENTIA_RATE_LIMIT_MAX_KEYS=100000

# Auth budgets (requests per window).
RL_LOGIN_ACCOUNT_LIMIT=5
RL_LOGIN_IP_LIMIT=20
RL_REGISTER_IP_LIMIT=5
RL_REFRESH_TOKEN_LIMIT=10
RL_PASSWORD_RESET_ACCOUNT_LIMIT=3
# Generation (LLM spend) — deliberately separate and much tighter.
RL_GENERATE_USER_LIMIT=10
RL_GENERATE_TENANT_LIMIT=30
RL_GENERATE_IP_LIMIT=20

# Hard cap on request body bytes (413 above this, enforced before parsing).
EVIDENTIA_MAX_BODY_BYTES=524288

# ==========================================================================
# LLM pipeline (optional: GENERATION is deterministic without a key)
#
# "No key needed" applies to the generation pipeline only. It does NOT mean the
# product runs without the backend or without the database — authentication,
# tenancy and persistence always require both.
# ==========================================================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

EVIDENTIA_USE_LLM=false
EVIDENTIA_LLM_PROVIDER=openai
EVIDENTIA_LLM_MODEL=gpt-4o-mini

# off | summary | full | auto
#   off     → deterministic only (0 LLM calls)
#   summary → deterministic + 1 LLM call to polish the narrative (recommended)
#   full    → deterministic + up to 3 LLM calls (more expensive)
#   auto    → calibrated router; resolves to summary on the current corpus
EVIDENTIA_LLM_INTENSITY=summary
EVIDENTIA_MAX_CONTEXT_CHARS=6000
EVIDENTIA_MAX_OUTPUT_TOKENS=700
EVIDENTIA_ENABLE_CACHE=true
EVIDENTIA_REPAIR_MIN_RELEVANCE=2.0
EVIDENTIA_MIN_EVIDENCE_SUPPORT=2
EVIDENTIA_ROUTER_FULL_GAIN_THRESHOLD=0.2
