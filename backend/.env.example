# Evidentia Python backend configuration
#
# The backend works fully offline with deterministic agents and NO keys.
# To enable LLM-assisted refinement, set EVIDENTIA_USE_LLM=true and add a key.
# Copy this file to .env (never commit real keys).

# --- LLM provider keys (owned by the backend; never sent to the frontend) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline configuration ---
EVIDENTIA_USE_LLM=false
EVIDENTIA_LLM_PROVIDER=openai
EVIDENTIA_LLM_MODEL=gpt-4o-mini

# LLM cost/quality mode: off | summary | full | auto
#   off     → deterministic only (0 LLM calls)
#   summary → deterministic + 1 LLM call to polish the narrative (recommended)
#   full    → deterministic + up to 3 LLM calls (more expensive; demos/testing)
#   auto    → picks off/summary/full per request from document complexity,
#             contradictions, citation coverage, persona complexity, confidence
EVIDENTIA_LLM_INTENSITY=summary
# Max characters of grounded context sent to the LLM
EVIDENTIA_MAX_CONTEXT_CHARS=6000
# Max output tokens per LLM call (summary mode is internally capped to 500)
EVIDENTIA_MAX_OUTPUT_TOKENS=700
# In-memory response cache (per server session) to avoid duplicate LLM calls
EVIDENTIA_ENABLE_CACHE=true
# Minimum relevance score for the deterministic grounding-repair scorer to accept
# a replacement citation; below this, an item is marked N/A (insufficient evidence).
EVIDENTIA_REPAIR_MIN_RELEVANCE=2.0

# Minimum evidence-support strength (signal terms + 2×phrases) for a risk or
# workflow step to be emitted as grounded from its source section (evidence-first
# generation). Below this the risk is dropped or, when relevant, an evidence-gap.
EVIDENTIA_MIN_EVIDENCE_SUPPORT=2

# Minimum predicted incremental overall-quality gain (points) for the auto router
# to select full mode over summary. Calibrated high because full is on average
# worse than summary on the v1 benchmark; see docs/ai/DECISIONS.md.
EVIDENTIA_ROUTER_FULL_GAIN_THRESHOLD=0.2

# --- Database ---
# Leave DATABASE_URL EMPTY for a zero-config local SQLite file
# (backend/evidentia.db) — recommended for the public demo. Set it to a managed
# PostgreSQL URL for durable persistence, e.g.
#   DATABASE_URL=postgresql://user:password@db-host:5432/evidentia
DATABASE_URL=
EVIDENTIA_DB_ENABLED=true

# --- Deployment ---
# Allowed CORS origins for the API. Use "*" for a keyless public demo, or a
# comma-separated allowlist of frontend origins for a locked-down deployment,
# e.g. EVIDENTIA_CORS_ORIGINS=https://evidentia.example.com
EVIDENTIA_CORS_ORIGINS=*
