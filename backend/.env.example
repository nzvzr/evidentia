# Evidentia Python backend configuration
#
# The backend works fully offline with deterministic agents and NO keys.
# To enable LLM-assisted refinement, set EVIDENTIA_USE_LLM=true and add a key.
# Copy this file to .env (never commit real keys).

# --- LLM provider keys (owned by the backend; never sent to the frontend) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline configuration ---
EVIDENTIA_USE_LLM=false
EVIDENTIA_LLM_PROVIDER=openai
EVIDENTIA_LLM_MODEL=gpt-4o-mini

# LLM cost/quality mode: off | summary | full
#   off     → deterministic only (0 LLM calls)
#   summary → deterministic + 1 LLM call to polish the narrative (recommended)
#   full    → deterministic + up to 3 LLM calls (more expensive; demos/testing)
EVIDENTIA_LLM_INTENSITY=summary
# Max characters of grounded context sent to the LLM
EVIDENTIA_MAX_CONTEXT_CHARS=6000
# Max output tokens per LLM call (summary mode is internally capped to 500)
EVIDENTIA_MAX_OUTPUT_TOKENS=700
# In-memory response cache (per server session) to avoid duplicate LLM calls
EVIDENTIA_ENABLE_CACHE=true

# --- Database ---
# PostgreSQL URL. If empty, a local SQLite file (backend/evidentia.db) is used.
DATABASE_URL=postgresql://user:password@localhost:5432/evidentia
EVIDENTIA_DB_ENABLED=true
