# Evidentia environment configuration
#
# Evidentia is an AUTHENTICATED, MULTI-TENANT app. The Python backend is required:
# it owns authentication, tenancy, and persistence. With EVIDENTIA_BACKEND_URL
# unset, login/register return 503 and the product is unusable — that is not a
# degraded mode, it is no auth at all.
#
# The pipeline still runs without an LLM key (deterministic mode).
# Copy this file to .env.local (never commit real keys).

# --- LLM provider keys (server-only; never exposed to the browser) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline configuration ---
# Provider to use when LLM is enabled: "openai" (Anthropic optional/later)
EVIDENTIA_LLM_PROVIDER=openai
# Model name for the selected provider
EVIDENTIA_LLM_MODEL=gpt-5.5
# Master switch — must be exactly "true" to enable LLM refinement
EVIDENTIA_USE_LLM=false

# --- Python backend (REQUIRED; server-only, never exposed to the browser) ---
# The Next.js BFF proxies to the FastAPI backend, which owns the LLM keys, the JWT
# secret, authentication and tenant isolation.
#
# NOT a rollback lever: unsetting this disables authentication for the whole app.
# The authenticated route returns 503 when the backend is unreachable — it never
# falls back to the TypeScript pipeline. The public TS demo lives only at
# /api/demo/generate-workflow (anonymous, public corpus, persists nothing).
# EVIDENTIA_BACKEND_URL=https://evidentia-backend.example.com

# Timeout (ms) for the generate-workflow proxy call to the backend. Generous by
# default to absorb cold starts; on timeout the route reports 503 (no fallback).
# EVIDENTIA_BACKEND_TIMEOUT_MS=45000
# Timeout (ms) for lightweight report read/list proxy calls to the backend.
# EVIDENTIA_BACKEND_READ_TIMEOUT_MS=8000

# --- Authentication (backend/.env; server-only) ---------------------------
# Authentication requires the Python backend: EVIDENTIA_BACKEND_URL must be set,
# or login/register return 503. There is no demo/anonymous mode any more.
#
# Signing key for JWT access tokens.
#
# PRODUCTION IS FAIL-FAST: with EVIDENTIA_ENV=production the backend REFUSES TO
# START unless JWT_SECRET is a CRYPTOGRAPHICALLY GENERATED secret — the base64url
# or hex encoding of at least 32 random bytes. Refused: missing, the dev default,
# known-weak values, repeated blocks, sequential runs, dictionary-like strings,
# narrow alphabets, low-entropy or highly compressible values, and anything that
# is not a valid ≥32-byte encoding. A weak key here forfeits every other
# control — anyone who recovers it can mint a token for any user in any tenant.
# Generate it with EXACTLY this command and paste the output:
#
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# JWT_SECRET=
#
# Production also refuses: EVIDENTIA_EMAIL_BACKEND=console (writes reset links to
# the logs), EVIDENTIA_CORS_ORIGINS=* , and a trusted proxy count > 0 without an
# EVIDENTIA_BFF_SECRET.
# EVIDENTIA_ENV=development          # set to "production" for a real deployment

# Token lifetimes. Access tokens are short-lived; the refresh token is the
# long-lived, revocable credential and is rotated on every use.
# ACCESS_TOKEN_TTL_MINUTES=15
# REFRESH_TOKEN_TTL_DAYS=30
# EMAIL_VERIFICATION_TTL_HOURS=24
# PASSWORD_RESET_TTL_MINUTES=60

# Block unverified users from tenant endpoints (off by default so a fresh
# install is usable before email delivery is wired up).
# EVIDENTIA_REQUIRE_EMAIL_VERIFICATION=false

# Email delivery for verification / password-reset links.
#   console = log the link (development; no provider needed)
#   noop    = drop the message
# Plug a real provider into app/services/email.py::EmailSender.
# EVIDENTIA_EMAIL_BACKEND=console
# EVIDENTIA_PUBLIC_APP_URL=http://localhost:3000   # base for links in emails

# --- Rate limiting & proxy trust ------------------------------------------
# IMPORTANT: rate-limit counters are per-process and in-memory. Running more than
# one backend replica multiplies every limit by the replica count. Use a single
# backend process, or swap in a shared store (see backend/app/core/ratelimit.py).
# EVIDENTIA_RATE_LIMIT_ENABLED=true
#
# Number of reverse proxies in front of the service whose X-Forwarded-For entries
# can be trusted. This is a SECURITY setting, and both tiers have their own:
#
#   Backend  — set to 1 when it sits behind the Next.js BFF (the normal topology).
#              At 0 it keys per-IP limits on the TCP peer, which behind the BFF is
#              a single address, so every user would share one IP budget.
#   Frontend — set to the number of proxies in front of Next (e.g. 1 for a CDN or
#              load balancer). At 0 (default) Next ignores inbound XFF entirely and
#              cannot be spoofed. Only raise it if a proxy really is in front.
#
# With N trusted hops only the Nth-from-the-right XFF entry is believed; anything
# a client prepends is discarded.
# EVIDENTIA_TRUSTED_PROXY_COUNT=0
#
# X-Real-IP is NEVER trusted (it is client-writable with no chain to validate).
# Only the X-Forwarded-For chain is used, and only at >0 trusted hops.

# Shared secret proving a request reached the backend via the Next.js BFF.
# REQUIRED in production whenever EVIDENTIA_TRUSTED_PROXY_COUNT > 0: a directly
# reachable backend would otherwise believe any client-supplied X-Forwarded-For.
# Set the SAME value in both the backend and the frontend environments.
# EVIDENTIA_BFF_SECRET=

# Cap on tracked rate-limit buckets (LRU eviction past it), so a flood of unique
# emails/tokens cannot exhaust memory.
# EVIDENTIA_RATE_LIMIT_MAX_KEYS=100000

# Public demo pipeline (/api/demo/generate-workflow): anonymous, non-persistent,
# runs in the Next process, so it gets its own IP-based cap.
# EVIDENTIA_DEMO_RATE_LIMIT=5
# EVIDENTIA_DEMO_RATE_WINDOW=3600

# Auth limits (backend). Defaults shown; tune per deployment.
# RL_LOGIN_ACCOUNT_LIMIT=5      / RL_LOGIN_ACCOUNT_WINDOW=900
# RL_LOGIN_IP_LIMIT=20          / RL_LOGIN_IP_WINDOW=900
# RL_REGISTER_IP_LIMIT=5        / RL_REGISTER_IP_WINDOW=3600
# RL_REFRESH_TOKEN_LIMIT=10     / RL_REFRESH_IP_LIMIT=60
# RL_PASSWORD_RESET_ACCOUNT_LIMIT=3  / RL_PASSWORD_RESET_IP_LIMIT=10
# Generation (LLM spend) — deliberately separate and much tighter:
# RL_GENERATE_USER_LIMIT=10     / RL_GENERATE_TENANT_LIMIT=30 / RL_GENERATE_IP_LIMIT=20

# Hard cap on request body bytes (413 above this, before parsing).
# EVIDENTIA_MAX_BODY_BYTES=524288
