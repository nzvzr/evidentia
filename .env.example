# Evidentia environment configuration
#
# The app works fully offline with deterministic agents and NO keys.
# To enable the LLM-assisted pipeline, set EVIDENTIA_USE_LLM=true and provide a key.
# Copy this file to .env.local (never commit real keys).

# --- LLM provider keys (server-only; never exposed to the browser) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Pipeline configuration ---
# Provider to use when LLM is enabled: "openai" (Anthropic optional/later)
EVIDENTIA_LLM_PROVIDER=openai
# Model name for the selected provider
EVIDENTIA_LLM_MODEL=gpt-5.5
# Master switch — must be exactly "true" to enable LLM refinement
EVIDENTIA_USE_LLM=false

# --- Optional Python backend (server-only; never exposed to the browser) ---
# If set, the Next.js API routes proxy to the FastAPI backend (which owns the LLM
# keys). If unset or offline, the built-in TypeScript pipeline is used instead so
# the demo always works. Use the backend's public URL in production. See
# backend/README.md and DEPLOYMENT.md.
# EVIDENTIA_BACKEND_URL=https://evidentia-backend.example.com

# Timeout (ms) for the generate-workflow proxy call to the backend. Generous by
# default to absorb free-tier cold starts; falls back to the TS pipeline on abort.
# EVIDENTIA_BACKEND_TIMEOUT_MS=45000
# Timeout (ms) for lightweight report read/list proxy calls to the backend.
# EVIDENTIA_BACKEND_READ_TIMEOUT_MS=8000
